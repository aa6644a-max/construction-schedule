generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  name         String
  projects     Project[]
  createdAt    DateTime  @default(now())
}

model Project {
  id         Int        @id @default(autoincrement())
  userId     Int
  name       String
  siteName   String
  startDate  DateTime
  endDate    DateTime
  shareToken String     @unique
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workItems  WorkItem[]
  createdAt  DateTime   @default(now())
}

model WorkItem {
  id             Int        @id @default(autoincrement())
  projectId      Int
  parentId       Int?
  code           String
  name           String
  weight         Float      @default(0)
  plannedStart   DateTime?
  plannedEnd     DateTime?
  actualProgress Float      @default(0)
  sortOrder      Int        @default(0)
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent         WorkItem?  @relation("WorkItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children       WorkItem[] @relation("WorkItemChildren")
  createdAt      DateTime   @default(now())
}
